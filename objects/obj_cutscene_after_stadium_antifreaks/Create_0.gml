/// @description Init

// Inherit the parent event
event_inherited();

cutscene_segment_set(0, "Superior: 'And once again we reign superior!'", spr_cutscene_swordsman_shadow_1,,, msc_cutscene_normal);
cutscene_segment_set(1, "Geyzer: 'Shut up! I hear someone approaching!'");

cutscene_segment_set(2, "Lord Humerus: 'Boo.'", spr_cutscene_swordsman_shadow_2,,, msc_boss_cinge,, cutscene_transitions.fade);
cutscene_segment_set(3, "Negative Quincy: 'Target sighted!'");
cutscene_segment_set(4, "Lord Humerus: 'Hold your fire. I've come to parlay!'");
cutscene_segment_set(5, "Trash Can Man: 'Oh goody! I love impulsively making sleazy deals. Lay it on me!'");
cutscene_segment_set(6, "Lord Humerus: 'Your enthusiasm and impulsiveness is noted.'");
cutscene_segment_set(7, "'Anyways, I invite you to join me, Anti Freaks. Like two dogs sharing spaghetti under the moonlight, our violent bitterness unites us. Abandon that foolish anti-matter moron and I'll show you what actually matters.'");
cutscene_segment_set(8, "Trash Can Man: 'I want $69420.67 up front, 99.9% residuals, movie and book rights, fancy limo, one of those wooden birds that dips its head into a glass of water--'");
cutscene_segment_set(9, "Superior: 'SHUT UP!!!'");
cutscene_segment_set(10, "Lord Humerus: '...why don't I come back later, when you've decided. Meet me back here with all of your trophies; I put them back on your proverbial shelves for you. Make the right choice.'");