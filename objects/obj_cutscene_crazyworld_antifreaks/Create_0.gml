/// @description Init

// Inherit the parent event
event_inherited();

cutscene_segment_set(0, "Kranion: 'So lemme get this straight. I eat this freakin' pahticle heyah and I get way strongah?", spr_cutscene_placeholder,,, msc_boss_kranion);
cutscene_segment_set(1, "Lord Humerus: 'You will paint the cosmos red with the blood of our enemies.'");
cutscene_segment_set(2, "Kranion: 'Yah friggin' weihd, bro. Yah lucky I like yah. Besides, I can do that stuff any time I want!");
cutscene_segment_set(3, "Lord Humerus: 'Then why haven't you?'");
cutscene_segment_set(4, "Kranion: 'I just said I like yah, don't make me my change my mind.'");
cutscene_segment_set(5, "Lord Humerus: 'No disrespect, my boy. I merely propose that you severely underestimate your own power.", spr_cutscene_placeholder,,,,, cutscene_transitions.NA);
cutscene_segment_set(6, "Kranion: 'Yah sayin' I can get even strongah? I was a black hole with my face a few houahs ago!'",,,,,, cutscene_transitions.NA);
cutscene_segment_set(7, "Lord Humerus: 'Several years ago, The Shadow powered you up with the same kind of particle we hold right now.'",,,,,, cutscene_transitions.NA);
cutscene_segment_set(8, "Kranion: 'Yah, I drove ah fohklift with it! It was friggin awesome!.'",,,,,, cutscene_transitions.NA);
cutscene_segment_set(9, "Lord Humerus: 'How would you like to drive ten forklifts, Kranion? Twenty? Hundreds? All at the same time? With uh...I don't know, a little poodle riding in each one? Train with me. I will show you your true potential.'", spr_cutscene_placeholder,,,,, cutscene_transitions.NA);
cutscene_segment_set(10, "Kranion: 'Well when yah put it like that? Yah, suh thing.'",,,,,, cutscene_transitions.NA);